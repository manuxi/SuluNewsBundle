<?xml version="1.0" encoding="utf-8"?>
<properties xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xmlns="http://schemas.sulu.io/template/template"
            xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <block name="quote" default-type="quote">
        <types>
            <type name="quote">
                <meta>
                    <title>sulu_news.block.quote</title>
                </meta>
                <properties>
                    <property name="quote" type="text_area">
                        <meta>
                            <title>sulu_news.block.quote_text</title>
                        </meta>
                    </property>
                    <property name="source" type="text_line">
                        <meta>
                            <title>sulu_news.block.quote_source</title>
                        </meta>
                    </property>
                </properties>
            </type>
        </types>
    </block>
</properties>
