<?xml version="1.0" encoding="utf-8"?>
<properties xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xmlns="http://schemas.sulu.io/template/template"
            xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <block name="title_text_image" default-type="title_text_image">
        <types>
            <type name="title_text_image">
                <meta>
                    <title>sulu_news.block.title_text_image</title>
                </meta>
                <properties>
                    <property name="title" type="text_line">
                        <meta>
                            <title>sulu_news.title</title>
                        </meta>
                    </property>
                    <property name="text" type="text_editor" colspan="8">
                        <meta>
                            <title>sulu_news.text</title>
                        </meta>
                    </property>
                    <property name="image" type="single_media_selection" colspan="4">
                        <meta>
                            <title>sulu_news.image</title>
                        </meta>
                        <params>
                            <param name="types" value="image"/>
                        </params>
                    </property>
                </properties>
            </type>
        </types>
    </block>
</properties>
