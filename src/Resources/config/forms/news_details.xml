<?xml version="1.0" ?>
<form xmlns="http://schemas.sulu.io/template/template"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:xi="http://www.w3.org/2001/XInclude"
    xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/form-1.0.xsd"
>
    <key>news_details</key>

    <properties>
        <section name="header_container" colspan="12">
            <meta>
                <title>sulu_news.header.content</title>
            </meta>
            <properties>
                <section name="image_section" colspan="4">
                    <properties>
                        <property name="image" type="single_media_upload" colspan="12">
                            <params>
                                <!--<param name="skin" value="round"/>-->
                                <param name="empty_icon" value="su-image"/>
                                <param name="image_size" value="sulu-400x400"/>
                                <param
                                        name="collection_id"
                                        type="expression"
                                        value="service('sulu_media.system_collections.manager').getSystemCollection('sulu_news.news')"
                                />
                            </params>
                        </property>
                    </properties>
                </section>

                <section name="content_section" colspan="8">
                    <properties>
                        <property name="title" type="text_line" mandatory="true">
                            <meta>
                                <title>sulu_news.title</title>
                            </meta>
                            <params>
                                <param name="headline" value="true"/>
                            </params>
                            <tag name="sulu.rlp.part"/>
                        </property>

                        <property name="subtitle" type="text_line">
                            <meta>
                                <title>sulu_news.subtitle</title>
                            </meta>
                        </property>

                        <property name="routePath" type="route" mandatory="true">
                            <meta>
                                <title>sulu_admin.url</title>
                            </meta>
                            <!--https://github.com/sulu/sulu/pull/5933-->
                            <params>
                                <param name="mode" value="leaf"/>
                            </params>
                        </property>
                    </properties>
                </section>
            </properties>
        </section>

        <section name="content_main">
            <properties>
                <property name="type" type="single_select" mandatory="true" colspan="6">
                    <meta>
                        <title>sulu_news.news_type</title>
                    </meta>
                    <params>
                        <param name="default_value"
                               type="expression"
                               value="service('sulu_news.type_selection').getDefaultValue()"
                        />
                        <param name="values"
                               type="expression"
                               value="service('sulu_news.type_selection').getValues()"
                        />
                    </params>
                </property>

                <property name="summary" type="text_area" mandatory="true">
                    <meta>
                        <title>sulu_news.summary</title>
                    </meta>
                </property>

                <property name="text" type="text_editor" mandatory="true">
                    <meta>
                        <title>sulu_news.text</title>
                    </meta>
                </property>
            </properties>
        </section>

        <section name="content_blocks">
            <meta>
                <title>sulu_news.content_blocks</title>
            </meta>
            <properties>
                <block name="blocks" default-type="title_text" minOccurs="0">
                    <meta>
                        <title>sulu_news.content_blocks</title>
                    </meta>
                    <types>
                        <xi:include href="../form-includes/blocks/title_text.xml"
                                    xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)xpointer(/sulu:properties/sulu:block/sulu:types/*)"/>
                        <xi:include href="../form-includes/blocks/title_text_image.xml"
                                    xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)xpointer(/sulu:properties/sulu:block/sulu:types/*)"/>
                        <xi:include href="../form-includes/blocks/title_text_images.xml"
                                    xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)xpointer(/sulu:properties/sulu:block/sulu:types/*)"/>
                        <xi:include href="../form-includes/blocks/quote.xml"
                                    xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)xpointer(/sulu:properties/sulu:block/sulu:types/*)"/>
                    </types>
                </block>
            </properties>
        </section>

        <section name="optional">
            <meta>
                <title>sulu_news.header.additional</title>
            </meta>
            <properties>

                <property name="images" type="media_selection">
                    <meta>
                        <title>sulu_news.gallery</title>
                    </meta>
                    <params>
                        <param name="types" value="image,video"/>
                    </params>
                </property>
                <property name="footer" type="text_editor">
                    <meta>
                        <title>sulu_news.footer</title>
                    </meta>
                </property>

                <property name="link" type="link" colspan="6">
                    <meta>
                        <title>sulu_news.link</title>
                    </meta>
                    <params>
                        <param name="enable_anchor" value="false"/>
                        <param name="enable_attributes" value="true"/>
                    </params>
                </property>
                <property name="pdf" type="single_media_selection" colspan="6">
                    <meta>
                        <title>sulu_news.pdf</title>
                    </meta>
                    <params>
                        <param name="types" value="document"/>
                    </params>
                </property>
                <property name="showAuthor" type="checkbox" colspan="3">
                    <meta>
                        <title>sulu_news.show_author</title>
                    </meta>
                </property>
                <property name="showDate" type="checkbox" colspan="3">
                    <meta>
                        <title>sulu_news.show_date</title>
                    </meta>
                </property>
            </properties>
        </section>
    </properties>
</form>
